APP_NAME=agentic-analytics-copilot
APP_ENV=local
DUCKDB_PATH=data/structured/operations.duckdb
CHROMA_PATH=data/vector/chroma
CHROMA_COLLECTION_NAME=ops_knowledge_base
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_API_KEY=
JWT_SECRET=local-demo-secret
JWT_ALGORITHM=HS256
RATE_LIMIT_PER_MINUTE=10
HYBRID_SEARCH_RRF_K=60
HYBRID_SEARCH_VECTOR_CANDIDATES=20
HYBRID_SEARCH_KEYWORD_CANDIDATES=20
RETRIEVAL_FINAL_LIMIT=5
RERANKER_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2
SEMANTIC_CACHE_PATH=data/cache/semantic_cache.sqlite
SEMANTIC_CACHE_SIMILARITY_THRESHOLD=0.95
OBSERVABILITY_DB_PATH=data/cache/observability.sqlite
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
